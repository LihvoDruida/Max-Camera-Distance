package-as: Max_Camera_Distance

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - .releaserc
  - .vscode
  - .git
  - .github
  - screenshots
  - package.json
  - package-lock.json
  - release.sh
  - cliff.toml
  - .DS_Store

externals:
  libs/LibStub:
    url: svn://svn.wowace.com/wow/libstub/mainline/trunk

  libs/CallbackHandler-1.0:
    url: svn://svn.wowace.com/wow/callbackhandler/mainline/trunk/CallbackHandler-1.0

  libs/AceAddon-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceAddon-3.0

  libs/AceGUI-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceGUI-3.0

  libs/AceConfig-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceConfig-3.0

  libs/AceDB-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceDB-3.0

  libs/AceDBOptions-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceDBOptions-3.0

  libs/AceLocale-3.0:
    url: svn://svn.wowace.com/wow/ace3/mainline/trunk/AceLocale-3.0

  libs/LibMountInfo:
    url: https://github.com/LudiusMaximus/LibMountInfo

  libs/LibDataBroker-1.1:
    url: svn://svn.wowace.com/wow/libdatabroker-1-1/mainline/trunk

  libs/LibDBIcon-1.0:
    url: svn://svn.wowace.com/wow/libdbicon-1-0/mainline/trunk/LibDBIcon-1.0